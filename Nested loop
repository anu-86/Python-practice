Excercise Programs
#1.Write a nested loop to print all combinations of i and j from 1 to 3.

for i in range(1,4):
	for j in range(1,4):
		print(i,j)

#2.Write a nested loop where i goes from 1 to 3 and j goes from 1 to 2.

for i in range (1,4):
	for j in range (1,3):
		print(i,j)

#3.Write a nested loop and use continue to skip when j == 2.

for i in range (1,4):
	for j in range (1,4):
	  if j ==2:
		  continue
	  print(i,j)

#4.Write a nested loop and use break to stop the loop when i == 2.

for i in range (1,4):
	if i ==2:
			break
	for j in range(1,4):
		print(i,j)

#5.Write a nested loop using range(3) and range(2)

for i in range(0,3):
	for j in range(0,2):
		print(i,j)
